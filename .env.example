# Backend Configuration
BACKEND_PORT=3000
BACKEND_HOST=0.0.0.0
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=emailserver
DB_PASSWORD=changeme
DB_NAME=emailserver_db
DB_SSL=false

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Email Server
SMTP_PORT=25
SMTP_TLS_PORT=587
SMTP_SSL_PORT=465
IMAP_PORT=143
IMAP_SSL_PORT=993
POP3_PORT=110
POP3_SSL_PORT=995

# Mail Server Config
HOSTNAME=mail.example.com
DOMAIN=example.com
PRIMARY_DOMAIN=example.com

# Admin Configuration
ADMIN_API_PORT=3001
ADMIN_API_KEY=your-admin-key-here
JWT_SECRET=your-jwt-secret-here
JWT_EXPIRY=7d

# Email Gateway
GATEWAY_PORT=8080
GATEWAY_ENABLED=true
GATEWAY_HOSTNAME=filter.example.com

# SMTP Authentication
SMTP_AUTH_ENABLED=true

# TLS/SSL
TLS_ENABLED=true
TLS_CERT_PATH=/certs/server.crt
TLS_KEY_PATH=/certs/server.key

# Spam Filter
SPAM_FILTER_ENABLED=true
SPAM_SCORE_THRESHOLD=5.0
ENABLE_ML_SPAM_DETECTION=true

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Frontend
REACT_APP_API_URL=http://localhost:3000
REACT_APP_ADMIN_API_URL=http://localhost:3001

# Security
CORS_ORIGIN=*
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Email Archiving
EMAIL_ARCHIVING_ENABLED=true
ARCHIVE_RETENTION_DAYS=2555

# DKIM/SPF/DMARC
ENABLE_DKIM_SIGNING=true
ENABLE_SPF_CHECK=true
ENABLE_DMARC_COMPLIANCE=true
